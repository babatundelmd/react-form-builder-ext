    "builder",
    "ui",
    "drag",
    "drop"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Babatunde Lamidi",
  "contributors": [],
  "dependencies": {
    "@babel/runtime-corejs3": "^7.28.0",
