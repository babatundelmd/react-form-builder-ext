    "classnames": "^2.2.6",
    "clsx": "^2.1.1",
    "date-fns": "^2.16.1",
    "debounce": "^2.2.0",
    "draft-js": "^0.11.7",
    "draftjs-to-html": "^0.8.4",
    "es6-promise": "^4.2.8",
    "fbemitter": "^3.0.0",
    "file-saver": "^2.0.5",
    "immutability-helper": "^3.1.1",
    "isomorphic-fetch": "^3.0.0",
    "lucide-react": "^0.474.0",
    "papaparse": "^5.5.3",
    "prop-types": "^15.8.1",
    "react-bootstrap-slider": "^2.2.3",
    "react-currency-input-field": "^3.9.0",
    "react-datepicker": "^3.8.0",
    "react-dnd": "^11.1.3",
    "react-dnd-html5-backend": "^11.1.3",
    "react-draft-wysiwyg": "^1.14.7",
    "react-intl": "^5.24.3",
    "react-select": "^3.2.0",
    "react-signature-canvas": "^1.0.3",
    "react-textarea-autosize": "^7.1.2",
    "react-toastify": "^11.0.5",
    "xlsx": "^0.18.5",
    "xss": "^1.0.8"
  },
  "peerDependencies": {
    "react": ">=17.0.0 <19.0.0",
    "react-dom": ">=17.0.0 <19.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.12.10",
    "@babel/core": "^7.28.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-json-strings": "^7.12.1",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/plugin-transform-runtime": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "add": "^2.0.6",
    "autoprefixer": "^10.4.20",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^8.4.1",
    "copyfiles": "^2.4.1",
    "core-js": "^3.43.0",
    "cross-env": "^7.0.3",
    "css-loader": "^3.6.0",
    "ejs": "^2.7.4",
    "eslint": "^6.8.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.22.0",
    "express": "^4.17.1",
    "multer": "^1.4.2",
    "postcss": "^8.5.1",
    "postcss-loader": "^8.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^3.0.2",
    "sass": "^1.52.3",
    "sass-loader": "^10.5.2",
    "style-loader": "^1.3.0",
    "tailwindcss": "^3.4.17",
    "webpack": "^5.99.9",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  },
  "scripts": {
    "build": "webpack --mode production --config webpack.production.config.js",
    "build:dev": "webpack --mode development",
    "build:umd": "webpack --mode development --config webpack.production.config.js",
    "build:style": "sass ./scss/application.scss dist/app.css --style compressed && npx tailwindcss -i dist/app.css -o dist/app.css",
    "build:lib": "npx tailwindcss -i ./src/styles/style.css -o ./src/styles/final.css && npm run transpile && npm run build:style",
    "build:dist": "npm run build && npm run copy:dist",
    "clean": "rimraf dist",
    "copy:dist": "copyfiles -f \"./dist/*\" \"./public/dist\"",
    "prepublishOnly": "npm run clean && npm run build:lib && npm run build",
    "watch": "webpack --watch",
    "start": "webpack-dev-server --hot --mode development",
    "serve:api": "node server/index.js",
    "pretranspile": "rimraf lib",
    "transpile": "babel --out-dir lib src --copy-files",
    "tw": "npx tailwindcss -i ./src/styles/style.css -o ./src/styles/final.css --watch"
  }
}
